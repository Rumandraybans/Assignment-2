<!DOCTYPE html>
<html>

<head>

    <title>Students</title>

    <style>

        body{
            font-family: Arial;
            background-color: #f4f4f4;
            margin: 0;
            padding: 20px;
        }

        .container{
            width: 80%;
            margin: auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0px 0px 10px gray;
        }

        h1{
            text-align: center;
            color: #333;
        }

        .top-bar{
            text-align: center;
            margin-bottom: 20px;
        }

        .top-bar a{
            text-decoration: none;
            background: #007bff;
            color: white;
            padding: 10px 15px;
            border-radius: 5px;
            font-weight: bold;
        }

        .top-bar a:hover{
            background: #0056b3;
        }

        table{
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th{
            background: #007bff;
            color: white;
            padding: 12px;
        }

        td{
            padding: 12px;
            text-align: center;
            border: 1px solid #ccc;
        }

        tr:nth-child(even){
            background-color: #f9f9f9;
        }

        .edit-btn{
            text-decoration: none;
            background: green;
            color: white;
            padding: 6px 12px;
            border-radius: 5px;
        }

        .delete-btn{
            text-decoration: none;
            background: red;
            color: white;
            padding: 6px 12px;
            border-radius: 5px;
        }

        .edit-btn:hover{
            background: darkgreen;
        }

        .delete-btn:hover{
            background: darkred;
        }

    </style>

</head>

<body>

<div class="top-bar">

    <a href="/">Home</a>

    <a href="/about">About Us</a>

    <a href="/contact">Contact Us</a>

    <a href="/students/add">Add Student</a>

</div>

    <table>

        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Course</th>
            <th>Marks</th>
            <th>Actions</th>
        </tr>

        <% students.forEach(student => { %>

        <tr>

            <td><%= student.id %></td>
            <td><%= student.name %></td>
            <td><%= student.course %></td>
            <td><%= student.marks %></td>

            <td>

                <a
                    class="edit-btn"
                    href="/students/edit/<%= student.id %>"
                >
                    Edit
                </a>

                <a
                    class="delete-btn"
                    href="/students/delete/<%= student.id %>"
                >
                    Delete
                </a>

            </td>

        </tr>

        <% }) %>

    </table>

</div>

</body>
</html>