<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="py-5">

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                
                <a href="/students" class="btn btn-link text-decoration-none p-0 mb-3 text-muted">
                    <i class="bi bi-arrow-left"></i> Back to Dashboard
                </a>

                <div class="card overflow-hidden">
                    <div class="bg-dark p-4 text-center border-bottom">
                        <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center mb-2 shadow" style="width: 70px; height: 70px;">
                            <i class="bi bi-person-fill display-6"></i>
                        </div>
                        <h3 class="fw-bold text-white mb-0"><%= student.name %></h3>
                        <span class="badge bg-secondary mt-2">Roll No: <%= student.rollno %></span>
                    </div>

                    <div class="p-4 bg-white">
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="p-2 border rounded bg-light">
                                    <small class="text-muted d-block text-uppercase font-monospace fs-7">Course</small>
                                    <span class="fw-semibold text-dark"><%= student.course %></span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-2 border rounded bg-light">
                                    <small class="text-muted d-block text-uppercase font-monospace fs-7">Age</small>
                                    <span class="fw-semibold text-dark"><%= student.age %> Years</span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="p-2 border rounded bg-light">
                                    <small class="text-muted d-block text-uppercase font-monospace fs-7">Email Address</small>
                                    <span class="fw-semibold text-dark"><%= student.email %></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="p-2 border rounded bg-light">
                                    <small class="text-muted d-block text-uppercase font-monospace fs-7">City</small>
                                    <span class="fw-semibold text-dark"><%= student.city %></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-light p-3 d-flex justify-content-end gap-2">
                        <a href="/students/edit/<%= student._id %>" class="btn btn-warning px-4 fw-semibold text-dark">
                            <i class="bi bi-pencil me-1"></i> Edit Profile
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>

</body>
</html>