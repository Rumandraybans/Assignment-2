<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Student</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="py-5">

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                
                <a href="/students" class="btn btn-link text-decoration-none p-0 mb-3 text-muted">
                    <i class="bi bi-arrow-left"></i> Back to Dashboard
                </a>

                <div class="card p-4 p-sm-5">
                    <h2 class="fw-bold mb-4 text-dark text-center">Add New Student</h2>
                    
                    <form action="/students/add" method="POST" onsubmit="return confirm('Do you want to save this student to the registry?');">
                        
                        <div class="mb-3">
                            <label class="form-label small fw-semibold text-muted">Full Name</label>
                            <input type="text" name="name" placeholder="Name Here" class="form-control form-control-lg" required>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-semibold text-muted">Roll Number</label>
                                <input type="number" name="rollno" placeholder="101" class="form-control form-control-lg" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-semibold text-muted">Age</label>
                                <input type="number" name="age" placeholder="20" class="form-control form-control-lg" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-semibold text-muted">Course / Major</label>
                            <input type="text" name="course" placeholder="Computer Science" class="form-control form-control-lg" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-semibold text-muted">Email Address</label>
                            <input type="email" name="email" placeholder="xyz@example.com" class="form-control form-control-lg" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-semibold text-muted">City</label>
                            <input type="text" name="city" placeholder="Noida" class="form-control form-control-lg" required>
                        </div>

                        <button class="btn btn-primary btn-lg w-100 fw-bold shadow-sm py-2">
                            <i class="bi bi-check-lg me-1"></i> Register Student
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

</body>
</html>